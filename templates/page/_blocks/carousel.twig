<section class="block block--carousel" data-theme="{{ block.theme }}" data-size="{{ block.size }}">
    <div class="container">
        {% if block.heading|length %}<h2>{{ block.heading }}</h2>{% endif %}
        <div class="carousel">
            {% for slide in block.slides.all() %}
                <div class="carousel__slide">
                    {% if slide.image|length %}
                        {% set img = slide.image.one() %}
                        <img src="{{ img.url }}" alt="{{ img.title }}">
                    {% endif %}
                    {% if slide.caption|length %}<p class="carousel__caption">{{ slide.caption }}</p>{% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
</section>
